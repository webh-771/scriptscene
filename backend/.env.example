# --- LLM (required for topic->script): free at https://console.groq.com ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- TTS ---
# engine: "edge" (cloud, free, no key) or "kokoro" (local, most natural)
TTS_ENGINE=edge
# edge voice (most natural: Andrew/Ava/Emma/Brian)
TTS_VOICE=en-US-AndrewNeural
# kokoro voice (am_michael, am_adam, af_heart, af_bella, bm_george, ...)
KOKORO_VOICE=am_michael

# --- Captions (local, free) ---
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# --- Royalty-free b-roll (optional if you supply local backgrounds) ---
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- YouTube upload (optional; run scripts/youtube_auth.py to fill these) ---
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=

# --- Video ---
VIDEO_FPS=30

CORS_ORIGINS=http://localhost:3000
