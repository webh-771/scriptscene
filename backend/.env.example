# --- LLM (required): free at https://console.groq.com ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- TTS (free, no key) ---
TTS_VOICE=en-US-GuyNeural

# --- Captions (local, free) ---
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# --- Royalty-free b-roll (optional if you supply local backgrounds) ---
# Free keys: https://www.pexels.com/api/  |  https://pixabay.com/api/docs/
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- YouTube upload (optional; run scripts/youtube_auth.py to fill these) ---
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=

# --- Video format ---
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

CORS_ORIGINS=http://localhost:3000
